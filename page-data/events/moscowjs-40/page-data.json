b7f5f8e7d2207a1ef3fca48053ead9/ca075/5a8d4c23a90ef50001077646_eqmQUNQ0_400x400.jpg 400w","sizes":"(max-width: 150px) 100vw, 150px"}}}]}}}]}},{"data":{"Title":"DX w/ Flow","Slides_URL":"https://cloud.mail.ru/public/M3pd/s8HyLYmSH","Theses":"Поговорим про DX и Flow. Как с помощью типизации можно увеличить свою продуктивность и повысить качество продукта.\n","Record":"https://www.youtube.com/watch?v=PKmqTiiPEw4","Date":["2018-03-01"],"Meetup":[{"data":{"Date":"1 марта 2018 г., 18:45","Video_link":null,"Title":"MoscowJS 40","Slug":"moscowjs-40"}}],"Speakers":[{"data":{"Name":"Александр Лобашев","Company":"Raiffeisen Bank Russia","Photo":{"localFiles":[{"childImageSharp":{"fluid":{"base64":"data:image/jpeg;base64,","aspectRatio":1,"src":"/static/49a5425f100b045aaead5800e9882ba1/4096a/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg","srcSet":"/static/49a5425f100b045aaead5800e9882ba1/cfba2/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg 38w,\n/static/49a5425f100b045aaead5800e9882ba1/da174/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg 75w,\n/static/49a5425f100b045aaead5800e9882ba1/4096a/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg 150w,\n/static/49a5425f100b045aaead5800e9882ba1/b0804/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg 225w,\n/static/49a5425f100b045aaead5800e9882ba1/b0650/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg 300w,\n/static/49a5425f100b045aaead5800e9882ba1/cd670/5a8a8be2d9716c0001a58c5b_AAEAAQAAAAAAAAPUAAAAJDIzOTg5ZGYwLTI0MTUtNGY0NS04OGViLTY0NjAwZDVjNWI4NA201.jpg 337w","sizes":"(max-width: 150px) 100vw, 150px"}}}]}}}]}},{"data":{"Title":"Обработка текстов в JavaScript для чайников​","Slides_URL":"https://cloud.mail.ru/public/58pk/ckocL8veR","Theses":"Коммуникация в виде текстовой информации является наиболее частым из используемых способов общения между людьми и интерфейсами в интернете. Для обработки подобной информации обычно используются решения, которые написаны на языке Python или R, но разработчики не ограничены этими языками для решения прикладных задач. В своем докладе я покажу, как, например, можно с помощью родного JavaScript исправлять ошибки в словах, понимать, к какой части речи они относятся, правильно их склонять или как классифицировать тексты между собой и понимать, на каком человеческом языке они были написаны.\n","Record":"https://www.youtube.com/watch?v=ATmtPyLmMdY","Date":["2018-03-01"],"Meetup":[{"data":{"Date":"1 марта 2018 г., 18:45","Video_link":null,"Title":"MoscowJS 40","Slug":"moscowjs-40"}}],"Speakers":[{"data":{"Name":"Дмитрий Шмаков","Company":"Revolut","Photo":{"localFiles":[{"childImageSharp":{"fluid":{"base64":"data:image/jpeg;base64,","aspectRatio":1,"src":"/static/4e393d17062c712607e9e5509208e144/4096a/5a8a8d2a37147b0001ae6bb9_shmakov.jpg","srcSet":"/static/4e393d17062c712607e9e5509208e144/cfba2/5a8a8d2a37147b0001ae6bb9_shmakov.jpg 38w,\n/static/4e393d17062c712607e9e5509208e144/da174/5a8a8d2a37147b0001ae6bb9_shmakov.jpg 75w,\n/static/4e393d17062c712607e9e5509208e144/4096a/5a8a8d2a37147b0001ae6bb9_shmakov.jpg 150w,\n/static/4e393d17062c712607e9e5509208e144/b0804/5a8a8d2a37147b0001ae6bb9_shmakov.jpg 225w,\n/static/4e393d17062c712607e9e5509208e144/b0650/5a8a8d2a37147b0001ae6bb9_shmakov.jpg 300w,\n/static/4e393d17062c712607e9e5509208e144/45488/5a8a8d2a37147b0001ae6bb9_shmakov.jpg 512w","sizes":"(max-width: 150px) 100vw, 150px"}}}]}}}]}}],"Title":"MoscowJS 40","Type":"Offline","Video_link":null,"Venue":[{"data":{"Slug":"avito-hall","Name":"Avito Hall"}}]}}},"pageContext":{"id":"ed18dc64-1393-5d30-9b19-8dd2714f6934"}},"staticQueryHashes":["3150323597","3477189030","3477189030","4130114283","4130114283"]}