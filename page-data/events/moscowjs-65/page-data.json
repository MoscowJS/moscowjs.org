1ade4/a7e7e/L1B4Fbi22emHK39pwdBzGPJreiLFt05Ljd1UchkIvao.png 1x,\n/static/a8c3a5c5a989c44462ad49734221ade4/05ef1/L1B4Fbi22emHK39pwdBzGPJreiLFt05Ljd1UchkIvao.png 1.5x,\n/static/a8c3a5c5a989c44462ad49734221ade4/a7c38/L1B4Fbi22emHK39pwdBzGPJreiLFt05Ljd1UchkIvao.png 2x"}}}]}}}],"Talks":[{"data":{"Title":"AI и безопасность при работе с NPM","Slides_URL":null,"Theses":"Работа с реестром NPM и использование опенсорс-библиотек - непосредственная часть работы фронтенд-разработчика. Однако помимо полезных и классных пакетов в NPM содержатся и библиотеки, чьей целью является кража ваших данных, получение доступа к вашим сервисам и устройствам. Так было всегда, но с развитием нейросетей публикация хакерских пакетов вышла на новый уровень. Сегодня посмотрим на проблему с двух сторон - как ИИ помогает писать вредоносный код хакерам и как белые и пушистые обычные фронтендеры тоже могут воспользоваться мощностями ИИ для предотвращения атак на их код.\n","Record":null,"Date":["2025-06-05"],"Start":null,"Scene":null,"Meetup":[{"data":{"Date":"2025-06-05T19:00:00.000Z","Video_link":null,"Title":"MoscowJS 65","Slug":"moscowjs-65"}}],"Speakers":[{"data":{"Name":"Анастасия Егорова","Company":null,"Photo":{"localFiles":[{"childImageSharp":{"fluid":{"base64":"data:image/jpeg;base64,","aspectRatio":1,"src":"/static/6b92d5b12a7f59bf137fd3a652946388/4096a/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFmWsvUxJo.jpg","srcSet":"/static/6b92d5b12a7f59bf137fd3a652946388/cfba2/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFmWsvUxJo.jpg 38w,\n/static/6b92d5b12a7f59bf137fd3a652946388/da174/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFmWsvUxJo.jpg 75w,\n/static/6b92d5b12a7f59bf137fd3a652946388/4096a/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFmWsvUxJo.jpg 150w,\n/static/6b92d5b12a7f59bf137fd3a652946388/b0804/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFmWsvUxJo.jpg 225w,\n/static/6b92d5b12a7f59bf137fd3a652946388/b0650/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFmWsvUxJo.jpg 300w,\n/static/6b92d5b12a7f59bf137fd3a652946388/3a31d/sX9CSoGcANuXMfgFm5luhnd-WISGJ5de9uFm